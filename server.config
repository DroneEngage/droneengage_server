{
    "server_id"                     : "DE_CommSrv",
    "server_ip"                     : "::",
    "public_host"                   : "127.0.0.1",
    "server_port"                   : 9966,
    "s2s_ws_target_ip"              : "127.0.0.1",
    "s2s_ws_target_port"            : "19001",
    "ssl_key_file"                  : "./ssl_local/ssl_airgap/domain.key",
    "ssl_cert_file"                 : "./ssl_local/ssl_airgap/domain.crt",
    "allow_fake_SSL"                : true,
    "ca_cert_path"                  : "./ssl_local/ssl_airgap/root.crt",
    "ignoreLoadingTasks"            : true,
    "allow_udpproxy_fixed_port"     : true,
    // Server-to-Server (S2S) authentication. Ed25519 key pair generated by gen_s2s_keys.js
    // Comm server CONNECTS to Auth (needs private key).
    // s2s_auth_enabled is managed by the authenticator only; comm server always attempts S2S auth.
    "s2s_my_private_key"            : "./ssl_local/DE_ServerComm_private.pem",
    // Storage server endpoint for direct connection
    "enable_storage_server"         : false,
    "storage_server_host"           : "127.0.0.1",
    "storage_server_port"           : 9000,
    // logging
    "ignoreLog"                 : true,
    "log_directory"             : "./logs/",
    "log_timeZone"              : "GMT",
    "log_detailed"              : false,

    "ws_compression"            : false,
    //server reboot - reboot server when process memory exceeds a certain limit.
    "memory_max"                : 973       // in MB  

}
