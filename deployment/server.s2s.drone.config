{
    "server_id"                      : "DronCommServer",
    "server_ip"                      : "0.0.0.0", 
    "public_host"                    : "127.0.0.1",
    "server_port"                    : 9967,
    "enable_SSL"                     : true,
    "dbIP"                          : "localhost",
    "dbuser"                        : "DBUSER",
    "dbpassword"                    : "DBPASSWORD",
    "dbdatabase"                    : "andruav",
    "s2s_ws_target_ip"               : "127.0.0.1",
    "s2s_ws_target_port"             : "19001",
    "ssl_key_file"                   : "./ssl_local/ssl_airgap/domain.key",
    "ssl_cert_file"                  : "./ssl_local/ssl_airgap/domain.crt",     
    "allow_fake_SSL"                 : true, // https://stackoverflow.com/questions/23601989/client-certificate-validation-on-server-side-depth-zero-self-signed-cert-error
    "ignoreLoadingTasks"             : true,
    "allow_udpproxy_fixed_port"      : true,

    // Server-to-Server (S2S) authentication. Ed25519 key pair generated by gen_s2s_keys.js
    // Drone server CONNECTS to Auth and Super server (needs private key).
    // Auth is controlled by its own config.
    "s2s_my_private_key"            : "./ssl_local/DronCommServer_private.pem",

    // super-server
    "enable_super_server"            : false,   // accepts channels from other servers.
    "s2s_super_server_ip"            : "127.0.0.1",
    "s2s_super_server_port"          : 9866,
    
    
    "enable_persistant_relay"        : true,    // connects to super server
    "s2s_relay_to_super_server_ip"   : "127.0.0.1",
    "s2s_relay_to_super_server_port" : 9866,
    
    // Local Server
    "local_server_enabled"           : true,
    "ignore_auth_server"             : true,
    "local_server_account_id"        : "1xx",
    
     
    


    // logging
    "ignoreLog"                 : true,
    "log_directory"             : "./logs/",
    "log_timeZone"              : "GMT",
    "log_detailed"              : true,

    //server reboot
    "memory_max"                : 373       // in MB

}
	
